# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# Public tunnel URL pointing at your local backend (no trailing slash)
# Get it from: cloudflared.exe tunnel --url http://localhost:8000
PUBLIC_LOCAL_VAULT_URL=https://<your-tunnel>.trycloudflare.com

# OpenAI API key — used server-side in +server.ts
OPENAI_API_KEY=
