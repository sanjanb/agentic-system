# Copy this file to .env.local and fill in your values.

# Required by server endpoints and AI tools.
# Must point to your FastAPI vault base URL (no trailing slash).
# Example: LOCAL_VAULT_URL=https://<your-tunnel>.trycloudflare.com
LOCAL_VAULT_URL=

# Optional public URL if you need client-side reads.
PUBLIC_LOCAL_VAULT_URL=

# OpenAI API key used by /api/chat.
OPENAI_API_KEY=
